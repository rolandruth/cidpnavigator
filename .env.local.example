# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used for embeddings only (text-embedding-3-small)
# Get from platform.openai.com
OPENAI_API_KEY=sk-proj-...

# Google Analytics 4 — get from analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
# Leave blank to disable GA (safe during development)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google AdSense — get from adsense.google.com after approval
# Format: ca-pub-XXXXXXXXXXXXXXXX
# Leave blank to disable ads (safe during development)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Your deployed domain (used for sitemap)
NEXT_PUBLIC_SITE_URL=https://cidpnavigator.com

# Supabase — get from your project Settings > API
# The public URL and anon key are safe to expose; service role key is server-only
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
